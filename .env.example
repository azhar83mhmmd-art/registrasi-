# Copy this file to .env and fill in your Supabase project values.
# Dashboard: https://app.supabase.com -> your project -> Settings -> API

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# service_role secret key (NOT the anon/public key — this must stay server-side only)
SUPABASE_SERVICE_ROLE_KEY=
